# Dockerfile.mcp — analyst_toolkit MCP Server
#
# Build:  docker build -f Dockerfile.mcp -t analyst-toolkit-mcp .
# Run:    docker compose -f docker-compose.mcp.yml up
#
# The server exposes a JSON-RPC 2.0 /rpc endpoint on port 8001,
# compatible with fridai-core's HTTPRemoteClient.

FROM python:3.13-slim

WORKDIR /app

# Install dependencies from project metadata.
# requirements-mcp.txt is a thin compatibility shim that resolves to .[mcp],
# including the release-backed analyst_toolkit_deploy wheel pin from pyproject.toml.
COPY pyproject.toml .
COPY README.md .
COPY requirements-mcp.txt .
COPY src/ src/
COPY config/ config/
RUN apt-get update && apt-get install -y --no-install-recommends git \
    && rm -rf /var/lib/apt/lists/* \
    && pip install --no-cache-dir -r requirements-mcp.txt

# Runtime defaults
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app/src
ENV ANALYST_MCP_HOST=0.0.0.0

EXPOSE 8001

# Health check
HEALTHCHECK --interval=30s --timeout=15s --start-period=30s --retries=5 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8001/health', timeout=3)"

CMD ["python", "-m", "analyst_toolkit.mcp_server.server"]
